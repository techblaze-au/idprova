{
  "name": "@idprova/core",
  "version": "0.1.2",
  "description": "IDProva core library — crypto, AID, DAT, receipts (napi-rs native bindings)",
  "license": "Apache-2.0",
  "homepage": "https://idprova.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techblaze-au/idprova.git",
    "directory": "sdks/typescript/packages/core"
  },
  "bugs": {
    "url": "https://github.com/techblaze-au/idprova/issues"
  },
  "keywords": [
    "identity",
    "ai-agent",
    "cryptography",
    "delegation",
    "audit",
    "did",
    "ed25519",
    "napi-rs"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "idprova",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run",
    "universal": "napi universal",
    "version": "napi version"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "vitest": "^1.6.0"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@idprova/core-win32-x64-msvc": "0.1.2",
    "@idprova/core-darwin-x64": "0.1.2",
    "@idprova/core-darwin-arm64": "0.1.2",
    "@idprova/core-linux-x64-gnu": "0.1.2",
    "@idprova/core-linux-arm64-gnu": "0.1.2",
    "@idprova/core-linux-x64-musl": "0.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
